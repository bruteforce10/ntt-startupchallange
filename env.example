NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional: restrict the gallery to a specific Cloudinary folder.
# Leave blank or remove this key to include every image.
CLOUDINARY_GALLERY_FOLDER=
CLOUDINARY_GALLERY_MAX_RESULTS=30
CLOUDINARY_REVALIDATE_SECONDS=300

